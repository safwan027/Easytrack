
{
  "manifest_version": 3,
  "name": "EasyTrack",
  "version": "1.2",
  "permissions": ["offscreen"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/alert.wav"],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ]
}