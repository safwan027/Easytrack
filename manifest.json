{
  "manifest_version": 3,
  "name": "Easytrack",
  "version": "1.0",
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://127.0.0.1:8000/*" 
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
