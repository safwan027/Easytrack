{
  "manifest_version": 3,
  "name": "EasyTrack WhatsApp",
  "version": "1.0",
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/alert.wav"],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ]
}